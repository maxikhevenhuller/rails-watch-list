<h1><%= @list.name %></h1>
<h3>Movies in this list:</h3>
<ul>
  <% @list.bookmarks.each do |bookmark| %>
    <li>
      <strong><%= bookmark.movie.title %></strong> - <%= bookmark.comment %>
      <%= link_to "Delete", bookmark_path(bookmark), data: { turbo_method: :delete, turbo_confirm: "Are you sure?" } %>
    </li>
  <% end %>
</ul>
<hr>
<h3>Add a movie to this list</h3>
<%= form_with model: [@list, @bookmark] do |f| %>
  <%= f.label :movie_id, "Select a Movie" %>
  <%= f.collection_select :movie_id, Movie.all, :id, :title %>

  <%= f.label :comment %>
  <%= f.text_field :comment %>

  <%= f.submit "Add Movie" %>
<% end %>
<%= link_to "Back to all lists", lists_path %>
